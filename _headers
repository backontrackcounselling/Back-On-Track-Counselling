  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' https://assets.calendly.com 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://assets.calendly.com; img-src 'self' data: https:; font-src 'self' data: https://cdnjs.cloudflare.com; frame-src https://calendly.com https://assets.calendly.com; connect-src 'self' https://calendly.com https://assets.calendly.com; object-src 'none'; base-uri 'self'; form-action 'self' https://calendly.com; upgrade-insecure-requests;
